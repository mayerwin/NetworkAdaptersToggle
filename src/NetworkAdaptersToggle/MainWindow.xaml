<Window x:Class="NetworkAdaptersToggle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetworkAdaptersToggle"
        Title="Network Adapters Toggle"
        Height="520" Width="780"
        MinHeight="400" MinWidth="600"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Network Adapters"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="Select adapters and use the buttons below to enable or disable them."
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Adapter List -->
        <Border Grid.Row="1" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" ClipToBounds="True">
            <DataGrid x:Name="AdapterGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      IsReadOnly="False"
                      RowHeight="36">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          Checked="OnAdapterSelectionChanged"
                                          Unchecked="OnAdapterSelectionChanged"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="STATUS" Width="110" SortMemberPath="Status" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUp}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding InterfaceDescription}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="IDX" Binding="{Binding InterfaceIndex}" Width="50" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Button Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="BtnEnable" Content="Enable Selected"
                    Style="{StaticResource EnableButton}"
                    Click="BtnEnable_Click"/>
            <Button x:Name="BtnDisable" Content="Disable Selected"
                    Style="{StaticResource DisableButton}"
                    Click="BtnDisable_Click"/>
            <Button x:Name="BtnRefresh" Content="Refresh"
                    Style="{StaticResource RefreshButton}"
                    Click="BtnRefresh_Click"/>

            <Separator Width="20" Visibility="Hidden"/>

            <Button x:Name="BtnSelectAll" Content="Select All"
                    Style="{StaticResource ActionButton}"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource TextDimBrush}"
                    Click="BtnSelectAll_Click"/>
            <Button x:Name="BtnSelectNone" Content="Select None"
                    Style="{StaticResource ActionButton}"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource TextDimBrush}"
                    Click="BtnSelectNone_Click"/>
        </StackPanel>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,6" CornerRadius="4"
                Background="{StaticResource SurfaceBrush}">
            <TextBlock x:Name="StatusText" Text="Loading adapters..."
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="11.5"
                       Foreground="{StaticResource TextDimBrush}"/>
        </Border>
    </Grid>
</Window>
